;; в”Ӯв–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–‘в–‘в–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–Җв–„в–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–„в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–Ҳв–„в–Ҳв–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–„в–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–‘в–‘в–Ҳв–Җв–Җв–‘в–Ҳв–Җв–Җв”Ӯ
;; в”Ӯв–‘в–Ҳв–Җв–Җв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–‘в–‘в–‘в–Ҳв–‘в–‘в–Ҳв–Җв–„в–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–„в–‘в–‘в–‘в–‘в–Җв–‘в–‘в–‘в–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–‘в–‘в–Ҳв–Җв–Җв–‘в–Җв–Җв–Ҳв”Ӯ
;; в”Ӯв–‘в–Җв–‘в–‘в–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв–‘в–‘в–Җв–‘в–‘в–Җв–Җв–‘в–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–‘в–‘в–‘в–Җв–‘в–‘в–‘в–‘в–Җв–‘в–Җв–‘в–Җв–Җв–Җв–‘в–Җв–Җв–‘в–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв”Ӯ
;; в”Ӯв–‘Createdв–‘Byв–‘Adityaв–‘Shakyaв–‘@adi1090xв–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в–‘в”Ӯ
;; в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
;;
;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[module/pulseaudio]
type = internal/pulseaudio
;type = internal/alsa

format-volume = <ramp-volume>  <label-volume>
format-muted = <label-muted> 0%
label-volume = %percentage%%

label-muted = пҖҰ
; label-muted = пұқ
; label-muted-foreground = ${color.fg-alt}

ramp-volume-0 = пҖҰ
ramp-volume-1 = пҖ§
ramp-volume-2 = пҖЁ
ramp-volume-3 = пҖЁ

;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[module/battery]
type = internal/battery

; This is useful in case the battery never reports 100% charge
; Default: 100
full-at = 98

; format-low once this charge percentage is reached
; Default: 10
; New in version 3.6.0
low-at = 5

; Use the following command to list batteries and adapters:
; $ ls -1 /sys/class/power_supply/
battery = BAT0
adapter = ADP1

; If an inotify event haven't been reported in this many
; seconds, manually poll for new values.
;
; Needed as a fallback for systems that don't report events
; on sysfs/procfs.
;
; Disable polling by setting the interval to 0.
;
; Default: 5
poll-interval = 5

; see "man date" for details on how to format the time string
; NOTE: if you want to use syntax tags here you need to use %%{...}
; Default: %H:%M:%S
time-format = %H:%M

; Available tags:
;   <label-charging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-charging>
format-charging = <animation-charging> <label-charging>

; Available tags:
;   <label-discharging> (default)
;   <bar-capacity>
;   <ramp-capacity>
;   <animation-discharging>
format-discharging = <ramp-capacity> <label-discharging>

; Available tags:
;   <label-full> (default)
;   <bar-capacity>
;   <ramp-capacity>
;format-full = <ramp-capacity> <label-full>

; Format used when battery level drops to low-at
; If not defined, format-discharging is used instead.
; Available tags:
;   <label-low>
;   <animation-low>
;   <bar-capacity>
;   <ramp-capacity>
; New in version 3.6.0
;format-low = <label-low> <animation-low>

; Available tokens:
;   %percentage% (default) - is set to 100 if full-at is reached
;   %percentage_raw%
;   %time%
;   %consumption% (shows current charge rate in watts)
label-charging = %%percentage%%

; Available tokens:
;   %percentage% (default) - is set to 100 if full-at is reached
;   %percentage_raw%
;   %time%
;   %consumption% (shows current discharge rate in watts)
label-discharging = %%percentage%%

; Available tokens:
;   %percentage% (default) - is set to 100 if full-at is reached
;   %percentage_raw%
label-full = пүҖ  %%percentage%

; Available tokens:
;   %percentage% (default) - is set to 100 if full-at is reached
;   %percentage_raw%
;   %time%
;   %consumption% (shows current discharge rate in watts)
; New in version 3.6.0
label-low = BATTERY LOW

; Only applies if <ramp-capacity> is used
ramp-capacity-0 = пү„
ramp-capacity-1 = пүғ
ramp-capacity-2 = пүӮ
ramp-capacity-3 = пүҒ
ramp-capacity-4 = пүҖ

; Only applies if <bar-capacity> is used
bar-capacity-width = 10

; Only applies if <animation-charging> is used
animation-charging-0 = пү„
animation-charging-1 = пүғ
animation-charging-2 = пүӮ
animation-charging-3 = пүҒ
animation-charging-4 = пүҖ
; Framerate in milliseconds
animation-charging-framerate = 750

; Only applies if <animation-discharging> is used
animation-discharging-0 = пүҖ
animation-discharging-1 = пүҒ
animation-discharging-2 = пүӮ
animation-discharging-3 = пүғ
animation-discharging-4 = пү„
; Framerate in milliseconds
animation-discharging-framerate = 500

; Only applies if <animation-low> is used
; New in version 3.6.0
animation-low-0 = !
animation-low-1 = 
animation-low-framerate = 200


;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[module/date]
type = internal/date

interval = 1.0

;time = "%a %b %d    %I:%M %p"
;time = "%a, %b %d, %Y | %H:%M:%S" 
time = "%a. %Y/%m/%d | %H:%M:%S" 
;time = "%I:%M %p"
;time-alt = %B %d, %Y

format = <label>
label = %time%

;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[module/network]
type = internal/network

interface = enp52s0
interval = 1.0

accumulate-stats = true
unknown-as-up = true

format-connected = <label-connected>
format-connected-perfix = пҮ«
format-disconnected = <label-disconnected>

; label-connected = %downspeed:9%
; label-disconnected = %downspeed:9%
ramp-signal = "%downspeed%%{A}"
label-connected = "пҮ«   %downspeed%%{A}"
label-disconnected = "у°–Ә "
; label-disconnected-foreground = ${color.fg-alt}


;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[module/wired-network]
type = internal/network
interface = enp52s0
interval = 1.0

accumulate-stats = true
unknown-as-up = true

format-connected = <label-connected>
format-connected-perfix = у°ұ“
format-disconnected = <label-disconnected>

; label-connected = %downspeed:9%
; label-disconnected = %downspeed:9%
ramp-signal = "%downspeed%%{A}"
label-connected = "у°ұ“  %downspeed%%{A}"
label-disconnected = "у°…ӣ"
; label-disconnected-foreground = ${color.fg-alt}


[module/wireless-network]
type = internal/network
interface = wlan0
interval = 1.0

accumulate-stats = true
unknown-as-up = true

format-connected = <label-connected>
format-connected-perfix = пҮ«
format-disconnected = <label-disconnected>

; label-connected = %downspeed:9%
; label-disconnected = %downspeed:9%
ramp-signal = "%downspeed%%{A}"
label-connected = "пҮ«   %downspeed%%{A}"
label-disconnected = "у°–Ә"
; label-disconnected-foreground = ${color.fg-alt}

