[module/cpu]
type = internal/cpu

interval = 1
;
warn-percentage = 95
;
label = у°»   %percentage%%


[module/memory]
type = internal/memory

; ; Default: 1
interval = 1
;
warn-percentage = 95

label = у°Қӣ  %percentage_used%%
; label = RAM %used%/%total%


[module/networksp]
type = internal/network

interface = wlp1s0
interval = 1.0

; accumulate-stats = true
; unknown-as-up = true
format-connected = <label-connected>
;   <label-disconnected> (default)
format-disconnected = <label-disconnected>

label-connected = %downspeed:9%
label-disconnected = %downspeed:9%
label-disconnected-foreground = ${color.fg-alt}


[module/temperature]
type=internal/temperature

; Seconds to sleep between updates
; Default: 1
interval = 0.5

; Thermal zone to use
; To list all the zone types, run 
; $ for i in /sys/class/thermal/thermal_zone*; do echo "$i: $(<$i/type)"; done
; Default: 0
thermal-zone = 0

; Full path of temperature sysfs path
; Use `sensors` to find preferred temperature source, then run
; $ for i in /sys/class/hwmon/hwmon*/temp*_input; do echo "$(<$(dirname $i)/name): $(cat ${i%_*}_label 2>/dev/null || echo $(basename ${i%_*})) $(readlink -f $i)"; done
; to find path to desired file
; Default reverts to thermal zone setting

; hwmon-path = /sys/devices/platform/coretemp.0/hwmon/hwmon2/temp1_input
; hwmon-path = /sys/devices/platform/coretemp.0/hwmon/hwmon5/temp2_input
; hwmon-path = /sys/devices/pci0000:00/0000:00:06.2/0000:06:00.0/nvme/nvme1/hwmon2/temp1_input

internal = 1.0
format = <label>
label = пӢӢ  %temperature-c%
warn-temperature = 90
; format-warn = <label>
ramp-0 = пӢӢ
ramp-1 = пӢӢ
ramp-2 = пӢӢ
ramp-3 = пӢӢ
ramp-4 = пӢӢ
ramp-5 = пӢӢ


[module/light]
type = internal/backlight
card = acpi_video0
use-actual-brightness = true
enable-scroll = true
format = <ramp>  <label>
label =%percentage%%
; format-padding = 2

; ramp-0 = у°ғһ
; ramp-1 = у°ғҹ
; ramp-2 = у°ғқ
; ramp-3 = у°ғқ
; ramp-4 = у°ғ 

ramp-0 = у°ғң
ramp-1 = у°ғқ
ramp-2 = у°ғһ
ramp-3 = у°ғҹ
ramp-4 = у°ғ 

; ramp-0 = оҰЈ
; ramp-1 = оҰЈ
; ramp-2 = оҰҺ
; ramp-3 = о§Ј
; ramp-4 = о§Ј


[module/launcher]
type = custom/text
content = пҢғ 
content-foreground = ${color.blue-arch}


[module/i3]
type = internal/i3

pin-workspaces = true
show-urgent = true
strip-wsnumbers = true
index-sort = true
enable-click = true
enable-scroll = false
wrapping-scroll = false
reverse-scroll = false
fuzzy-match = true
format = <label-state> <label-mode>

; icon-[0-9]+ = <desktop-name>;<icon>
; NOTE: The desktop name needs to match the name configured by the WM
; You can get a list of the defined desktops using:
; $ xprop -root _NET_DESKTOP_NAMES
ws-icon-0 = 10;у°Ү® 
ws-icon-1 = 1;п’ү
ws-icon-2 = 2;пү© 
ws-icon-3 = 3;у°қҡ 
ws-icon-4 = 4;у°““ 
ws-icon-5 = 5;у°Қі 
ws-icon-6 = 6;оӘғ
ws-icon-7 = 7;уұ“©
ws-icon-8 = 8;оҲ—
ws-icon-9 = 9;у°ӯ№
ws-icon-default = у°Қ№

label-mode = %mode%
label-mode-padding = 3
; label-mode-background = #e60053
label-mode-foreground = #e60053

label-focused = %icon%
; label-focused-foreground = #d8dee9
label-focused-foreground = ${color.fg}
; label-focused-background = #4c566a
label-focused-underline = #fba922
label-focused-padding = 3

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon% %name%
label-unfocused = %icon%
; label-unfocused-foreground = #4c566a
label-unfocused-foreground = ${color.fg-alt}
label-unfocused-padding = 3

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon% %name%
label-visible = %icon%
; label-visible-underline = #555555
label-visible-padding = 3

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon% %name%
label-urgent = %icon%
; label-urgent-foreground = #000000
label-urgent-foreground = #bd2c40
label-urgent-padding = 3

; Separator in between workspaces
; label-separator = |
; label-separator-padding = 1
; ; label-separator-foreground = #ffb52a
; label-separetor-foreground = #d8dee9


[module/yay]

type = custom/script 
exec = ~/.config/polybar/scripts/yay.sh 


[module/cava]
type = custom/script
#exec = ~/.config/polybar/scripts/cava.py -f 24 -b 12 -e fffdfc,fffafe,ffeafa,ffc3d2 -c average
exec = ~/.config/polybar/scripts/cava.py -f 24 -b 30 -e fffdfc,fffafe,ffeafa,ffc3d2 -c average
tail = true

[module/tray]
type = internal/tray

format-margin = 8px
tray-spacing = 8px
